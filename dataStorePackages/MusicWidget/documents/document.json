{
  "type": "APL",
  "version": "1.7",
  "theme": "dark",
  "mainTemplate": {
    "parameters": [
      "payload"
    ],
    "items": [
      {
        "type": "TouchWrapper",
        "width": "100%",
        "height": "100%",
        "onPress": [
          {
            "type": "SendEvent",
            "arguments": [
              {
                "action": "launchIntent",
                "intentName": "PlayMusicIntent"
              }
            ],
            "flags": {
              "interactionMode": "STANDARD"
            }
          }
        ],
        "item": {
          "type": "Frame",
          "width": "100%",
          "height": "100%",
          "items": [
            {
              "type": "Image",
              "width": "100%",
              "height": "100%",
              "source": "${viewport.width > viewport.height ? payload.widgetData.imageL : payload.widgetData.imageM}",
              "scale": "best-fill"
            },
            {
              "type": "Container",
              "width": "100%",
              "height": "100%",
              "backgroundColor": "#00000055"
            },
            {
              "type": "Container",
              "width": "100%",
              "height": "100%",
              "direction": "column",
              "justifyContent": "end",
              "alignItems": "start",
              "paddingLeft": "${viewport.width > viewport.height ? '36dp' : '24dp'}",
              "paddingRight": "${viewport.width > viewport.height ? '36dp' : '24dp'}",
              "paddingBottom": "${viewport.width > viewport.height ? '24dp' : '20dp'}",
              "items": [
                {
                  "type": "Text",
                  "text": "${payload.widgetData.title}",
                  "fontSize": "${viewport.width > viewport.height ? '34dp' : '28dp'}",
                  "fontWeight": "700",
                  "color": "#FFFFFF",
                  "maxLines": 1
                },
                {
                  "type": "Text",
                  "text": "${payload.widgetData.subtitle}",
                  "fontSize": "${viewport.width > viewport.height ? '22dp' : '19dp'}",
                  "color": "#F3F4F6",
                  "paddingTop": "6dp",
                  "maxLines": 1
                },
                {
                  "type": "Text",
                  "text": "${payload.widgetData.duration}",
                  "fontSize": "${viewport.width > viewport.height ? '18dp' : '16dp'}",
                  "color": "#E5E7EB",
                  "paddingTop": "8dp",
                  "maxLines": 1
                }
              ]
            }
          ]
        }
      }
    ]
  }
}
